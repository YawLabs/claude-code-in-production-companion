# Force LF line endings for all text files, regardless of platform autocrlf
# settings. Without this, Windows checkouts of the demo overlay's JSON / TS
# files end up with CRLF and biome's formatter check fails.

*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.html text eol=lf
*.css text eol=lf
*.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
LICENSE text eol=lf

*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
